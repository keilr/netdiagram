{
  "name": "netdiagram",
  "version": "0.3.0",
  "description": "YAML-described network architecture diagrams, rendered as blueprint-style SVG schematics. Ships as a single self-contained HTML file.",
  "license": "MIT",
  "type": "commonjs",
  "main": "src/netdiagram.js",
  "scripts": {
    "build": "node scripts/build.js",
    "watch": "node scripts/watch.js",
    "render": "node scripts/render.js",
    "lint": "eslint .",
    "pretest": "node scripts/build.js",
    "test": "node test/test.js"
  },
  "keywords": [
    "network",
    "diagram",
    "yaml",
    "svg",
    "diagram-as-code",
    "elk"
  ],
  "dependencies": {
    "elkjs": "^0.11.1",
    "js-yaml": "^5.2.1"
  },
  "devDependencies": {
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/commands": "^6.10.4",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/lint": "^6.9.7",
    "@codemirror/state": "^6.7.1",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.6",
    "@eslint/js": "^10.0.1",
    "codemirror-json-schema": "^0.8.1",
    "esbuild": "^0.28.1",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1"
  }
}
